{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --session-start",
            "timeout": 15,
            "statusMessage": "Loading project memory…"
          },
          {
            "type": "command",
            "command": "python tools/memory.py --check-expiry",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --session-title",
            "timeout": 8,
            "refreshInterval": 60,
            "statusMessage": "Checking session state…"
          },
          {
            "type": "command",
            "command": "python tools/memory.py --capture-correction"
          },
          {
            "type": "command",
            "command": "python tools/memory.py --regret-guard",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python tools/memory.py --decision-guard",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python tools/memory.py --error-lookup",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --pre-edit",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --log-edit",
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --check-drift --silent",
            "async": true
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --verify-edit",
            "timeout": 5,
            "statusMessage": "Checking edit against plan…"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --suggest-guards",
            "if": "Edit(*error-lookup*)|Write(*error-lookup*)",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --permission-denied",
            "timeout": 5
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --permission-denied",
            "timeout": 8,
            "async": true
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --file-changed",
            "timeout": 5
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --session-start",
            "timeout": 15,
            "statusMessage": "Validating memory state…"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --precompact",
            "timeout": 15,
            "statusMessage": "Preserving memory through compaction…"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --postcompact",
            "timeout": 15,
            "statusMessage": "Restoring memory after compaction…"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --stop-failure",
            "timeout": 10,
            "statusMessage": "Capturing interruption state…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python tools/memory.py --process-corrections"
          },
          {
            "type": "command",
            "command": "python tools/memory.py --journal",
            "timeout": 10,
            "statusMessage": "Capturing session journal..."
          },
          {
            "type": "command",
            "command": "python tools/memory.py --stop-check",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
